    {
      "id": "en-tech-001",
      "language": "en",
      "category": "english_technical",
      "text": "Claude Code, Codex and GitHub Actions should all keep their exact capitalization.",
      "terms": ["Claude Code", "Codex", "GitHub Actions"]
