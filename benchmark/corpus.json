    },
    {
      "id": "da-long-002",
      "language": "da",
      "category": "long_danish",
      "text": "Hvis modellen bliver usikker, skal den hellere bevare de tekniske ord end prøve at oversætte dem til almindeligt dansk.",
      "terms": []
    },
    {
      "id": "en-short-001",
      "language": "en",
      "category": "short_english",
      "text": "Please check the latest build and tell me whether the tests are green.",
      "terms": []
    },
    {
      "id": "en-short-002",
      "language": "en",
      "category": "short_english",
      "text": "Create a pull request with a concise summary and the test results.",
      "terms": ["pull request"]
