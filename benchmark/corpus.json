    {
      "id": "da-tech-001",
      "language": "da",
      "category": "mixed_technical",
      "text": "Skift backend til Parakeet og behold dictionary replacements slået til.",
      "terms": ["Parakeet", "dictionary", "replacements"]
    },
    {
      "id": "da-tech-002",
      "language": "da",
      "category": "mixed_technical",
      "text": "Commit ændringen, push til main og opret et nyt git tag.",
      "terms": ["commit", "push", "main", "git tag"]
